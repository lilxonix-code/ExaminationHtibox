MainTab:CreateToggle({
    Name = "Enable Head Hitboxes",
    CurrentValue = false,
    Flag = "BigHeadToggle",
    Callback = function(value)
        if value then enableScript() else disableScript() end
    end,
})

MainTab:CreateInput({
    Name = "Head Hitbox Size",
    PlaceholderText = "Enter size (default: 4)",
    RemoveTextAfterFocusLost = false,
    Callback = function(value)
        local num = tonumber(value)
        if num and num > 0 then
            currentHeadSize = num
            if isEnabled then refreshAllModifiedParts() end
        end
    end,
})

MainTab:CreateInput({
    Name = "Hitbox Transparency",
    PlaceholderText = "Enter 0 (solid) to 1 (invisible), default: 0.5",
    RemoveTextAfterFocusLost = false,
    Callback = function(value)
        local num = tonumber(value)
        if num and num >= 0 and num <= 1 then
            currentHeadTransparency = num
            if isEnabled then refreshAllModifiedParts() end
        end
    end,
})

MainTab:CreateToggle({
    Name = "Affect Players",
    CurrentValue = false,
    Flag = "AffectPlayersToggle",
    Callback = function(value)
        affectPlayers = value
        -- If big head mode is active, rerun to apply/remove player heads
        if isEnabled then
            disableScript()
            enableScript()
        end
    end,
})

