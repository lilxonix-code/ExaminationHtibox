-- === ESP Highlight Tracking ===
local espHighlights = {}

local ZombieColors = {
    lurker = Color3.fromRGB(255, 0, 0),
    gunner = Color3.fromRGB(255, 100, 0),
    shielder = Color3.fromRGB(0, 0, 255),
    slasher = Color3.fromRGB(255, 0, 255),
    bomber = Color3.fromRGB(255, 255, 0),
    toxic = Color3.fromRGB(0, 255, 0),
    riser = Color3.fromRGB(255, 165, 0),
    mutant = Color3.fromRGB(128, 0, 128),
    chainsaw = Color3.fromRGB(255, 0, 128),
    chemical = Color3.fromRGB(0, 128, 255),
    dave = Color3.fromRGB(255, 0, 255),
    infected = Color3.fromRGB(0, 255, 0),
}

local ZombiePatterns = {
    {"chemical", "chemical"}, {"lurker", "lurker"}, {"gunner", "gunner"},
    {"shielder", "shielder"}, {"slasher", "slasher"}, {"bomber", "bomber"},
    {"toxic", "toxic"}, {"riser", "riser"}, {"mutant", "mutant"},
    {"chainsaw", "chainsaw"}, {"dave", "dave"}, {"infected", "infected"},
}

local ExcludedSet = {
    deadcitylurker=true, informant=true, npc=true, ammobox=true,
    gate=true, door=true, button=true, generator=true, corpse=true, mutantcorpse=true
}

local function isExcluded(name)
    if not name then return true end
    local lower = string.lower(name)
    if ExcludedSet[lower] then return true end
    for k in pairs(ExcludedSet) do
        if string.find(lower, k, 1, true) then return true end
    end
    return false
end

local function isPlayerCharacter(model)
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character == model then return true end
    end
    return false
end

local function getZombieType(obj)
    if not obj or not obj.Name then return nil end
    local name = string.lower(obj.Name)
    for _, pattern in ipairs(ZombiePatterns) do
        if string.find(name, pattern[1], 1, true) then return pattern[2] end
    end
    return nil
end

local function addHighlight(obj, color)
    if espHighlights[obj] then return end
    local h = Instance.new("Highlight")
    h.FillColor = color
    h.OutlineColor = Color3.fromRGB(255, 255, 255)
    h.FillTransparency = 0.4
    h.OutlineTransparency = 0
    h.Parent = obj
    espHighlights[obj] = h
end

local function removeAllHighlights()
    for obj, h in pairs(espHighlights) do
        if h and h.Parent then h:Destroy() end
        espHighlights[obj] = nil
    end
end

local function scanAndApplyESP()
    removeAllHighlights()

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") then
            if ESPConfig.Zombies.enabled then
                local zt = getZombieType(obj)
                if zt and not isExcluded(obj.Name) and not isPlayerCharacter(obj) then
                    local color = ZombieColors[zt] or Color3.fromRGB(255, 0, 0)
                    addHighlight(obj, color)
                end
            end

            if ESPConfig.Players.enabled then
                local player = Players:GetPlayerFromCharacter(obj)
                if player and player ~= Players.LocalPlayer then
                    local localPlayer = Players.LocalPlayer
                    local color
                    if ESPConfig.Players.showTeamColor then
                        local friendly = player.Team and localPlayer.Team and player.Team == localPlayer.Team
                        color = friendly and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
                    else
                        color = Color3.fromRGB(0, 255, 255)
                    end
                    addHighlight(obj, color)
                end
            end

            if ESPConfig.Monsters.enabled then
                local name = string.lower(obj.Name)
                if ESPConfig.Monsters.dave.enabled and string.find(name, "dave", 1, true) then
                    addHighlight(obj, Color3.fromRGB(255, 0, 255))
                elseif ESPConfig.Monsters.infected.enabled and string.find(name, "infected", 1, true) then
                    addHighlight(obj, Color3.fromRGB(0, 255, 0))
                end
            end

            if ESPConfig.Loot.enabled then
                local name = string.lower(obj.Name)
                if ESPConfig.Loot.lootCrate.enabled and string.find(name, "lootcrate", 1, true) then
                    addHighlight(obj, Color3.fromRGB(255, 165, 0))
                elseif ESPConfig.Loot.lootBoxModel.enabled and string.find(name, "lootbox", 1, true) then
                    addHighlight(obj, Color3.fromRGB(255, 200, 50))
                end
            end
        end

        if ESPConfig.Loot.enabled and ESPConfig.Loot.landmine.enabled then
            if obj:IsA("BasePart") and obj.Name == "Landmine" then
                local localChar = Players.LocalPlayer.Character
                if localChar then
                    local hrp = localChar:FindFirstChild("HumanoidRootPart")
                    if hrp and (obj.Position - hrp.Position).Magnitude <= 20 then
                        addHighlight(obj.Parent or obj, Color3.fromRGB(255, 0, 0))
                    end
                end
            end
        end
    end
end

-- === NPC Head Logic ===
local function isHumanoidModel(model)
    if not model or not model:IsA("Model") then return false end
    return model:FindFirstChildWhichIsA("Humanoid") ~= nil
end

local function shouldAffectModel(model)
    if not isHumanoidModel(model) then return false end
    local isPlayer = Players:GetPlayerFromCharacter(model) ~= nil
    if isPlayer then
        -- Only affect players (excluding local player) if toggle is on
        if not affectPlayers then return false end
        if model == Players.LocalPlayer.Character then return false end
    end
    return true
end

local function applyToPart(part)
    if not part or not part:IsA("BasePart") then return end
    if part.Name ~= "Head" then return end
    local model = part.Parent
    if shouldAffectModel(model) then
        if not modifiedParts[part] then
            modifiedParts[part] = {
                Size        = part.Size,
                CanCollide  = part.CanCollide,
                Transparency = part.Transparency,
            }
        end
        pcall(function()
            part.Size         = Vector3.new(currentHeadSize, currentHeadSize, currentHeadSize)
            part.CanCollide   = false
            part.Transparency = currentHeadTransparency
        end)
    end
end

local function revertPart(part, original)
    pcall(function()
        if part and part.Parent then
            part.Size         = original.Size
            part.CanCollide   = original.CanCollide
            part.Transparency = original.Transparency
        end
    end)
end

local function watchNameChanges(part, connections)
    if not part or not part:IsA("BasePart") then return end
    local conn = part:GetPropertyChangedSignal("Name"):Connect(function()
        applyToPart(part)
    end)
    table.insert(connections, conn)
end

local function refreshAllModifiedParts()
    for part in pairs(modifiedParts) do
        pcall(function()
            if part and part.Parent then
                part.Size         = Vector3.new(currentHeadSize, currentHeadSize, currentHeadSize)
                part.Transparency = currentHeadTransparency
            end
        end)
    end
end

local activeConnections = {}
local isEnabled = false

local function enableScript()
    isEnabled = true
    for _, desc in ipairs(Workspace:GetDescendants()) do
        applyToPart(desc)
        if desc:IsA("BasePart") then watchNameChanges(desc, activeConnections) end
    end
    local addedConn = Workspace.DescendantAdded:Connect(function(desc)
        if not isEnabled then return end
        applyToPart(desc)
        if desc:IsA("BasePart") then watchNameChanges(desc, activeConnections) end
    end)
    table.insert(activeConnections, addedConn)
end

local function disableScript()
    isEnabled = false
    for _, conn in ipairs(activeConnections) do conn:Disconnect() end
    activeConnections = {}
    for part, original in pairs(modifiedParts) do revertPart(part, original) end
    modifiedParts = {}
end

